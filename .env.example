# FinSight Environment Variables
# Copy this file to .env and fill in your values.
# NEVER commit .env to GitHub.

# ── AWS Configuration ─────────────────────────────────────────────────────────
# Do NOT set AWS_ACCESS_KEY_ID or AWS_SECRET_ACCESS_KEY here.
# The EC2 LabRole instance profile provides credentials automatically.
AWS_REGION=us-east-1

# ── S3 ────────────────────────────────────────────────────────────────────────
# Create this bucket in the S3 console (block all public access)
S3_BUCKET_NAME=finsight-documents-<your-name>

# ── RDS PostgreSQL ────────────────────────────────────────────────────────────
# Get the endpoint from: RDS → Databases → finsight → Connectivity
RDS_HOST=<your-rds-endpoint>.rds.amazonaws.com
RDS_PORT=5432
RDS_DB=finsight
RDS_USER=admin
RDS_PASSWORD=<choose-a-strong-password>

# ── SES Email Notifications ───────────────────────────────────────────────────
# Both addresses must be verified in SES (Sandbox mode in AWS Academy)
SES_SENDER_EMAIL=<your-verified-sender@example.com>
NOTIFICATION_EMAIL=<your-email@example.com>

# ── Flask ─────────────────────────────────────────────────────────────────────
FLASK_ENV=production
FLASK_PORT=5000

# ── Lambda → EC2 communication ────────────────────────────────────────────────
# Set this in the Lambda function's environment variables too
EC2_BACKEND_URL=http://<your-ec2-public-ip>:5000
